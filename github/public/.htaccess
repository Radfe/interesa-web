Options -Indexes
RewriteEngine On

# Blokuj citlive admin storage subory
RewriteRule ^storage/admin/ - [F,L]

# Nepretlacaj existujuce subory/priecinky
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# /go/<kod> -> go.php?code=<kod>
RewriteRule ^go/([A-Za-z0-9_-]+)/?$ go.php?code=$1 [QSA,L]

# Sekcie
RewriteRule ^(clanky)(/.*)?$ router.php [QSA,L]
RewriteRule ^(kategorie)(/.*)?$ router.php [QSA,L]

# Domov
RewriteRule ^$ index.php [L]

# Vsetko ostatne na router
RewriteRule ^.*$ router.php [QSA,L]
